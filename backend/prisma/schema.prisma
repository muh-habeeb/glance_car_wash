datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client"
  output   = "../src/generated/client"
}

enum Role {
  USER
  STAFF
  ADMIN
}

model User {
  id          String   @id @default(uuid())
  name        String
  email       String   @unique
  password    String
  phone       String?  // UAE phone number
  role        Role     @default(USER)
  is_active   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([role])
  @@index([is_active])
  @@index([role, is_active]) // Composite index for common "active staff" queries
}

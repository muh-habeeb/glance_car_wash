PORT=3500
NODE_ENV=development

# --- Database & Auth ---
DATABASE_URL="postgresql://postgres:password@localhost:5432/glance_car_wash?schema=public"
JWT_SECRET=your_jwt_secret_key_here_minimum_eight_characters
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# --- CORS & Security ---
CORS_ORIGIN=http://localhost:3000
ALLOWED_HELMET_URL=http://localhost:3000

# --- Error Tracking (Sentry / GlitchTip) ---
# Copy the DSN from your GlitchTip project settings to enable error tracking
SENTRY_DSN=

# =========================================================
#                    DOCKER SETTINGS 
# =========================================================
# These keys are ONLY used by docker-compose.yml to spin up 
# local services like GlitchTip and Redis.
# They are not imported into the Node.js backend.

GLITCHTIP_PORT=8000
GLITCHTIP_SECRET_KEY=change-this-secret
GLITCHTIP_DATABASE_URL=postgres://postgres:system@db:5432/glitchtip

# The password used to secure the local Redis container
GLITCHTIP_REDIS_PASSWORD=glitchtip_redis_pass
GLITCHTIP_REDIS_URL=redis://:glitchtip_redis_pass@redis:6379
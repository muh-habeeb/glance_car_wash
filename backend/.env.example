PORT=3500
NODE_ENV=development

# --- Database & Auth ---
DATABASE_URL="postgresql://postgres:password@localhost:5432/glance_car_wash?schema=public"
JWT_SECRET=your_jwt_secret_key_here_minimum_eight_characters
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
SUPERADMIN_EMAIL=superadmin@glance.com
SUPERADMIN_PASSWORD=superadmin_secure_password

# --- CORS & Security ---
CORS_ORIGIN=http://localhost:3000
ALLOWED_HELMET_URL=http://localhost:3000

# --- Error Tracking (Sentry.io) ---
# Set to "true" to enable Sentry error tracking, "false" to disable it to save your free tier limits
ENABLE_SENTRY="false"
# Copy the DSN from your Sentry.io project settings to enable error tracking
SENTRY_DSN=


# --- Better Auth ---
# A strong random secret for signing sessions (e.g., openssl rand -base64 32)
BETTER_AUTH_SECRET="your_strong_random_secret_here"
# The API Key for Better Auth Infrastructure (if using @better-auth/infra)
BETTER_AUTH_API_KEY="ba_your_api_key_here"
# The public URL where the Better Auth API is accessed from the browser.
# ⚠️ IMPORTANT: If you are using the Next.js Proxy Rewrite in production, this MUST be your FRONTEND URL (e.g. https://glanz-car-wash.vercel.app)
# If running locally, this can remain the backend port if not using the proxy.
BETTER_AUTH_URL="http://localhost:3000"

# --- Social Providers (OAuth) ---
# Obtain these credentials from the Facebook Developer Portal
FACEBOOK_CLIENT_ID=""
FACEBOOK_CLIENT_SECRET=""

# Obtain these credentials from the Google Cloud Console
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""



# --- SMTP Mailer ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=dddm@gmail.com
SMTP_PASS=